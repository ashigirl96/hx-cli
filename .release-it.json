{
	"hooks": {
		"after:bump": "oxfmt --write CHANGELOG.md"
	},
	"git": {
		"commitMessage": "release: v${version}",
		"tagName": "v${version}"
	},
	"github": {
		"release": true,
		"releaseName": "v${version}",
		"tokenRef": "GITHUB_TOKEN"
	},
	"npm": {
		"publish": false
	},
	"plugins": {
		"@release-it/conventional-changelog": {
			"preset": "conventionalcommits",
			"infile": "CHANGELOG.md",
			"ignoreRecommendedBump": true
		}
	}
}
