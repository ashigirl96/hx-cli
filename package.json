{
	"name": "@dawkinsuke/hooks",
	"version": "0.1.0",
	"description": "Claude Code hooks toolkit — write hooks with TypeScript, compile to settings.local.json",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/ashigirl96/hx-cli.git"
	},
	"bin": {
		"hx": "src/cli/index.ts"
	},
	"files": [
		"src",
		"templates"
	],
	"type": "module",
	"exports": {
		".": "./src/index.ts",
		"./runtime": "./src/runtime.ts"
	},
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"test": "bun test",
		"check": "oxlint --fix . && oxfmt --write .",
		"ci:check": "oxlint . && oxfmt --check .",
		"typecheck": "tsc --noEmit",
		"prepare": "lefthook install"
	},
	"devDependencies": {
		"@anthropic-ai/claude-agent-sdk": "latest",
		"@types/bun": "latest",
		"lefthook": "^2.1.4",
		"oxfmt": "latest",
		"oxlint": "latest",
		"typescript": "^5.7.0"
	},
	"peerDependencies": {
		"@anthropic-ai/claude-agent-sdk": ">=0.2.0"
	},
	"peerDependenciesMeta": {
		"@anthropic-ai/claude-agent-sdk": {
			"optional": true
		}
	},
	"engines": {
		"bun": ">=1.0.0"
	}
}
